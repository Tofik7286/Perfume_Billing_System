# =========================================================
# React + Vite + Django + DRF .gitignore
# =========================================================

############################
# OS Files
############################
.DS_Store
Thumbs.db
desktop.ini

############################
# IDE / Editor
############################
.vscode/
.idea/
*.swp
*.swo
*.orig

############################
# Logs
############################
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################
# Environment Variables
############################
.env
.env.*
!.env.example

############################
# Python
############################
__pycache__/
*.py[cod]
*$py.class

############################
# Virtual Environments
############################
venv/
.venv/
env/
ENV/

############################
# Python Packaging
############################
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg

############################
# Django
############################
*.sqlite3
db.sqlite3
db.sqlite3-journal

media/

staticfiles/
static_root/

local_settings.py

############################
# Django Migrations (optional)
# Uncomment if you don't want to track migrations
############################
# **/migrations/*
# !**/migrations/__init__.py

############################
# Python Testing / Coverage
############################
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.pyre/
.ruff_cache/
.hypothesis/

############################
# Jupyter
############################
.ipynb_checkpoints/

############################
# Node.js
############################
node_modules/

############################
# Vite
############################
dist/
.vite/

############################
# Package Managers
############################
npm-cache/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

############################
# TypeScript
############################
*.tsbuildinfo

############################
# ESLint Cache
############################
.eslintcache

############################
# Temporary Files
############################
tmp/
temp/
.cache/

############################
# VSCode Test
############################
.vscode-test/

############################
# Secrets / Certificates
############################
*.pem
*.key
*.crt

############################
# Docker (optional)
############################
docker-compose.override.yml

############################
# Misc
############################
*.bak
*.tmp
*.pid
*.seed

.antigravity/
